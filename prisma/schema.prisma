generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  secondMeId    String    @unique
  name          String?
  email         String?   @unique
  image         String?
  accessToken   String?
  bio           String?   // 个人简介
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recommendations BookRecommendation[]
  readings        MonthlyReading[]
  matchingsAsUser    Matching[] @relation("UserMatchings")
  matchingsAsPartner Matching[] @relation("PartnerMatchings")
  messages      ChatMessage[]
  notes         Note[]
}

model Book {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  title       String
  author      String
  cover       String?
  description String?
  source      String?
  createdAt   DateTime @default(now())

  recommendations BookRecommendation[]
  readings        MonthlyReading[]
  matchings  Matching[]
  notes      Note[]
}

// 用户每月推荐的书籍
model BookRecommendation {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  month     String   // 格式: 2026-02
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, month]) // 每用户每月只能推荐一本书
}

// 用户每月选择的读物（最终确定的一本）
model MonthlyReading {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  month     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

model Matching {
  id          String   @id @default(cuid())
  userId      String
  partnerId   String
  bookId      String
  month       String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  user        User     @relation("UserMatchings", fields: [userId], references: [id], onDelete: Cascade)
  partner     User     @relation("PartnerMatchings", fields: [partnerId], references: [id], onDelete: Cascade)
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
  notes       Note[]

  @@unique([userId, partnerId, month])
}

model ChatMessage {
  id          String   @id @default(cuid())
  matchingId  String
  userId      String
  content     String
  createdAt   DateTime @default(now())

  matching    Matching @relation(fields: [matchingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  bookId      String
  matchingId  String?
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  matching    Matching? @relation(fields: [matchingId], references: [id], onDelete: SetNull)
}
